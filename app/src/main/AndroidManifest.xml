<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 🔥 Core Permissions -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- 📩 (Optional) SMS Permission - uncomment ONLY if needed -->
    <!--
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    -->

    <!-- 🔍 Declare UPI apps (queries section) -->
    <queries>
        <package android:name="com.dreamplug.androidapp" /> <!-- CRED -->
        <package android:name="com.google.android.apps.nbu.paisa.user" /> <!-- GPay -->
    </queries>

    <application
        android:name=".CashDashApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Cashdash"
        tools:targetApi="31">
        
        <!-- 🔥 Firebase Notifications: Default Headers (Master Fix) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="cashdash_urgent_heads_up_v10" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_bell" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/white" />

        <!-- 🚀 Launcher Activity -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".EntryActivity"
            android:exported="true" />

        <!-- 🏠 Main Flow Activities -->
        <activity android:name=".MainActivity" android:exported="true" />
        <activity android:name=".AllocatorActivity" android:exported="true" />
        <activity android:name=".SetLimitActivity" android:exported="true" />
        <activity android:name=".ProfileActivity" android:exported="true" />
        <activity android:name=".MenuActivity" android:exported="true" />
        <activity android:name=".MoneyScheduleActivity" android:exported="true" />
        <activity android:name=".HistoryActivity" android:exported="true" />
        <activity android:name=".RigorActivity" android:exported="true" />
        <activity android:name=".CategoryAnalysisActivity" android:exported="true" />
        <activity android:name=".DetailHistoryActivity" android:exported="true" />
        <activity android:name=".BalanceSetupActivity" android:exported="true" />
        <activity android:name=".HelpActivity" android:exported="true" />
        <activity 
            android:name=".NotificationActivity" 
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="NotificationActivity" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- 📷 QR Scanner + Deep Link -->
        <activity
            android:name=".ScannerActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="cashdash" />
            </intent-filter>
        </activity>

        <!-- 📩 SMS Listener (Safe Optional Block)
             Only enable if you REALLY use SMS reading.
             Otherwise remove completely to avoid Play Protect block.
        -->
        <!--
        <receiver
            android:name=".SmsReceiver"
            android:permission="android.permission.BROADCAST_SMS"
            android:exported="true">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>
        -->

        <receiver
            android:name=".ScannerWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/scanner_widget_info" />
        </receiver>

        <!-- 🔥 Firebase Cloud Messaging Service -->
        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>
