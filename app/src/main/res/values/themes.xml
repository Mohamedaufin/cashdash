<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Cashdash" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:autofilledHighlight">@android:color/transparent</item>
        <item name="colorPrimary">@color/primary_purple</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:windowBackground">@color/app_bg</item>
    </style>


    <style name="keyBtn">
        <item name="android:layout_width">0dp</item>         <!-- takes space equally -->
        <item name="android:layout_height">0dp</item>        <!-- updated to 0dp to fix scaling -->
        <item name="android:layout_columnWeight">1</item>    <!-- forces equal width -->
        <item name="android:layout_margin">10dp</item>
        <item name="backgroundTint">@null</item>
        <item name="android:background">@drawable/bg_glass_3d_keypad</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_rowWeight">1</item>
    </style>



    <style name="Theme.Cashdash" parent="Base.Theme.Cashdash">
        <item name="android:autofilledHighlight">@android:color/transparent</item>
    </style>

    <!-- Splash Screen Theme: dark bg + custom icon (Android 12+) -->
    <style name="Theme.Cashdash.Splash" parent="Theme.Cashdash">
        <item name="android:windowSplashScreenBackground">@color/app_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
    </style>


    <!-- 3D POPUP MENU STYLES -->
    <style name="PopupMenu3D" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_3d_dropdown</item>
        <item name="android:dropDownVerticalOffset">8dp</item>
    </style>

    <style name="PopupMenuTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="popupMenuStyle">@style/PopupMenu3D</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- BOTTOM SHEET STYLE (Transparent background so we can use bg_main_gradient) -->
    <style name="BottomSheetDialogTheme" parent="Theme.Design.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
</resources>
