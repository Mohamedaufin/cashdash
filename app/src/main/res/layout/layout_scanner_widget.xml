<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Square Container (One UI style) centered to prevent stretching -->
    <FrameLayout
        android:id="@+id/widgetContainer"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_widget_squircle_white"
        android:padding="12dp">

        <!-- Scanner Brackets (Black Vector) -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:src="@drawable/ic_scanner_brackets"
            android:scaleType="fitCenter"
            android:contentDescription="Scan QR" />

        <!-- App Logo Pin (Small Shield Overlay) -->
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="-4dp"
            android:src="@drawable/ic_logo_shield"
            android:elevation="4dp"
            android:contentDescription="CashDash Logo" />

    </FrameLayout>

</FrameLayout>



