<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="70dp"
        android:paddingBottom="40dp">

        <!-- TITLE 1 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Until when is this tentative money for?"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="15dp"/>

        <!-- CALENDAR VIEW WRAPPER -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_panel"
            android:padding="10dp"
            android:layout_marginBottom="25dp">

            <CalendarView
                android:id="@+id/calendarView"
                android:layout_width="match_parent"
                android:layout_height="350dp" />
        </FrameLayout>

        <!-- TITLE 2 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How often do you receive money?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="15dp"/>

        <RadioGroup
            android:id="@+id/rgFrequency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbMonthly"
                android:text="Monthly (30 days)"
                android:textColor="@android:color/white"/>

            <RadioButton
                android:id="@+id/rbWeekly"
                android:text="Weekly (7 days)"
                android:textColor="@android:color/white"/>

            <RadioButton
                android:id="@+id/rbCustom"
                android:text="Custom (Days)"
                android:textColor="@android:color/white"/>
        </RadioGroup>

        <EditText
            android:id="@+id/etCustomDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter numbers of days"
            android:textColorHint="#B0B0B0"
            android:textColor="@android:color/white"
            android:inputType="number"
            android:padding="15dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="25dp"
            android:background="@drawable/bg_glass_input"
            android:visibility="gone" />

        <!-- SAVE BUTTON -->
        <Button
            android:id="@+id/btnSaveSchedule"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="Save Schedule"
            android:textSize="22sp"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_glass_3d"
            app:backgroundTint="@null"
            android:layout_marginTop="10dp"/>
    </LinearLayout>

</ScrollView>
