<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="@drawable/bg_glass_transaction"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:gravity="center_vertical">

    <!-- Title / Name of Expense -->
    <TextView
        android:id="@+id/txtTransTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:text="Title" />

    <!-- Category Name -->
    <TextView
        android:id="@+id/txtTransCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#B0C8FF"
        android:textSize="14sp"
        android:text="(CATEGORY)"
        android:layout_marginRight="15dp" />

    <!-- Amount -->
    <TextView
        android:id="@+id/txtTransAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FF4D4D"
        android:textSize="18sp"
        android:textStyle="bold"
        android:text="+500"
        android:shadowColor="#80FF4D4D"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="10" />
</LinearLayout>
