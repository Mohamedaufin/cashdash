<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_glass_3d">

    <!-- Top accent bar + title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="18dp"
        android:paddingBottom="12dp">

        <!-- Colored left accent bar -->
        <View
            android:id="@+id/viewAccentBar"
            android:layout_width="4dp"
            android:layout_height="36dp"
            android:background="#8BF7E6"
            android:layout_marginEnd="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Status badge (QUERY RESPONDED / WAITING FOR RESPONSE) -->
            <TextView
                android:id="@+id/tvNotificationTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUERY RESPONDED"
                android:textColor="#8BF7E6"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="3dp"/>

            <!-- Time-stamp right aligned -->
            <TextView
                android:id="@+id/tvNotificationTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08 Mar, 05:18 PM"
                android:textColor="#607DA5"
                android:textSize="11sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Thin separator below header -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#18FFFFFF"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"/>

    <!-- Query / subject text -->
    <TextView
        android:id="@+id/tvNotificationQuery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Subject: — \n\nQuestion: —"
        android:textColor="#B0C8FF"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.4"
        android:padding="18dp"
        android:paddingBottom="14dp"/>

    <!-- Separator before response -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#18FFFFFF"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"/>

    <!-- Response section -->
    <TextView
        android:id="@+id/tvNotificationReply"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Response: —"
        android:textColor="#E0EBF5"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.5"
        android:padding="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"/>

    <!-- Reply Input Section -->
    <LinearLayout
        android:id="@+id/layoutReplyBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="0dp"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#10FFFFFF"
            android:layout_marginBottom="14dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:background="@drawable/bg_glass_input"
            android:padding="4dp">

            <EditText
                android:id="@+id/edtReply"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Type your reply..."
                android:textColor="#FFFFFF"
                android:textColorHint="#80A0C0"
                android:background="@android:color/transparent"
                android:textSize="13sp"
                android:minHeight="48dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical"
                android:inputType="textMultiLine"
                android:maxLines="4"/>

            <ImageButton
                android:id="@+id/btnSendReply"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_send"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:tint="#FFFFFF"
                android:layout_margin="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Resolved Status Footer Overlay (Optional indicator) -->

    <!-- Resolved Status Footer Overlay (Optional indicator) -->
    <TextView
        android:id="@+id/tvResolvedStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✔ QUERY RESOLVED"
        android:textColor="#607DA5"
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="12dp"
        android:visibility="gone"
        android:letterSpacing="0.1"/>

</LinearLayout>
