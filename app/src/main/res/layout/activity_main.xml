<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/rootLayout"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <!-- ══════════════════════════════════ TOP BAR ══════════════════════════════════ -->

    <!-- Menu button: Professional Vector-Based Glass Icon (No Artifacts) -->
    <ImageView
        android:id="@+id/btnMenu"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="64dp"
        android:src="@drawable/ic_glass_menu_vector"
        android:background="@android:color/transparent"
        android:scaleType="fitCenter"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Menu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Greeting: perfectly aligned without glow -->
    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hello,"
        android:textColor="@android:color/white"
        android:textSize="23sp"
        android:textStyle="bold"
        android:layout_marginStart="8dp"
        android:transitionName="greeting_text_transition"
        app:layout_constraintStart_toEndOf="@id/btnMenu"
        app:layout_constraintTop_toTopOf="@id/btnMenu"
        app:layout_constraintBottom_toBottomOf="@id/btnMenu"/>

    <!-- Profile button with Glass Style -->
    <ImageView
        android:id="@+id/btnProfile"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="56dp"
        android:layout_marginEnd="16dp"
        android:padding="4dp"
        android:src="@drawable/ic_profile"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Profile"
        android:translationZ="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- ══════════════════════════════ NEXT MONEY BANNER ════════════════════════════ -->

    <TextView
        android:id="@+id/tvNextMoney"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Next money in 0 days"
        android:textColor="#B0C8FF"
        android:textSize="18sp"
        android:gravity="center"
        android:shadowColor="#1A2D8A"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="8"
        app:layout_constraintBottom_toTopOf="@id/walletContainer"
        android:layout_marginBottom="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ══════════════════════════════ WALLET CIRCLE ═════════════════════════════════ -->

    <FrameLayout
        android:id="@+id/walletContainer"
        android:layout_width="340dp"
        android:layout_height="340dp"
        android:elevation="24dp"
        android:translationZ="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting"
        app:layout_constraintBottom_toTopOf="@id/cardScanner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="65dp"
        android:layout_marginBottom="40dp">

        <!-- Outer glow ring (larger, blurred behind) -->
        <View
            android:layout_width="370dp"
            android:layout_height="370dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_wallet_glow"
            android:alpha="0.55"/>

        <!-- Progress ring (Custom Exquisite Gradient) -->
        <com.cash.dash.GradientCircularProgressView
            android:id="@+id/walletProgress"
            android:layout_width="340dp"
            android:layout_height="340dp"
            android:layout_gravity="center" />

        <!-- Center text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="₹5000"
                android:textColor="@android:color/white"
                android:textSize="32sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wallet balance"
                android:textStyle="bold"
                android:textColor="#B0C4FF"
                android:textSize="15sp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- ══════════════════════════════ ACTION CARDS ══════════════════════════════════ -->

    <!-- Scanner card — 3D extruded look -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardScanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:layout_marginStart="32dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="20dp"
        app:cardElevation="16dp"
        app:strokeWidth="0dp"
        android:translationZ="10dp"
        app:layout_constraintTop_toBottomOf="@id/walletContainer"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="110dp">

            <!-- 3D gradient background -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_3d_card"/>

            <LinearLayout
                android:id="@+id/layoutScanner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/iconScanner"
                    android:layout_width="110dp"
                    android:layout_height="77dp"
                    android:src="@drawable/ic_scanner"
                    android:contentDescription="Scanner"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scanner"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:shadowColor="#000C40"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="4"/>
            </LinearLayout>
        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Rigor Tracker card — 3D extruded look -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRigor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="32dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="20dp"
        app:cardElevation="16dp"
        app:strokeWidth="0dp"
        android:translationZ="10dp"
        app:layout_constraintTop_toBottomOf="@id/walletContainer"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="110dp">

            <!-- 3D gradient background -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_3d_card"/>

            <LinearLayout
                android:id="@+id/layoutRigor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/iconRigorTracker"
                    android:layout_width="103dp"
                    android:layout_height="75dp"
                    android:src="@drawable/ic_rigor_tracker"
                    android:contentDescription="Rigor Tracker"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rigor Tracker"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:shadowColor="#000C40"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="4"/>
            </LinearLayout>
        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ═════════════════════════════ BOTTOM NAV BAR ════════════════════════════════ -->

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="135dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_3d_bottom_nav"
        android:elevation="32dp"
        android:translationZ="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Allocator Tab -->
        <LinearLayout
            android:id="@+id/tabAllocator"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/iconAllocator"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_allocator"
                android:contentDescription="Allocator"
                android:translationZ="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Allocator"
                android:textColor="#D0E0FF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:shadowColor="#000C40"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="4"/>
        </LinearLayout>

        <!-- Home Tab -->
        <LinearLayout
            android:id="@+id/tabHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/iconHome"
                android:layout_width="166dp"
                android:layout_height="84dp"
                android:src="@drawable/ic_home"
                android:contentDescription="Home"
                android:translationZ="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp"
                android:shadowColor="#3A6AFF"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="6"/>
        </LinearLayout>

        <!-- History Tab -->
        <LinearLayout
            android:id="@+id/tabHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/iconHistory"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_history"
                android:contentDescription="History"
                android:translationZ="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textColor="#D0E0FF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:shadowColor="#000C40"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="4"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
