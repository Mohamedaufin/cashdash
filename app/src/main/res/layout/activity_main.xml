<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <!-- ViewPager for content sliding -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="135dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_3d_bottom_nav"
        android:elevation="32dp"
        android:translationZ="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Allocator Tab -->
        <LinearLayout
            android:id="@+id/tabAllocator"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconAllocator"
                android:layout_width="166dp"
                android:layout_height="84dp"
                android:src="@drawable/ic_allocator"
                android:contentDescription="Allocator"
                android:translationZ="6dp"
                android:scaleType="fitCenter"/>

            <TextView
                android:id="@+id/tvAllocator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Allocator"
                android:textColor="#D0E0FF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp"
                android:shadowColor="#000C40"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="4"/>
        </LinearLayout>

        <!-- Home Tab -->
        <LinearLayout
            android:id="@+id/tabHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconHome"
                android:layout_width="166dp"
                android:layout_height="84dp"
                android:src="@drawable/ic_home"
                android:contentDescription="Home"
                android:translationZ="6dp"
                android:scaleType="fitCenter"/>

            <TextView
                android:id="@+id/tvHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp"
                android:shadowColor="#3A6AFF"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="6"/>
        </LinearLayout>

        <!-- History Tab -->
        <LinearLayout
            android:id="@+id/tabHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconHistory"
                android:layout_width="166dp"
                android:layout_height="84dp"
                android:src="@drawable/ic_history"
                android:contentDescription="History"
                android:translationZ="6dp"
                android:scaleType="fitCenter"/>

            <TextView
                android:id="@+id/tvHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textColor="#D0E0FF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp"
                android:shadowColor="#000C40"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="4"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
