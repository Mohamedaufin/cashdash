<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="60px"
    android:paddingTop="60px"
    android:paddingEnd="60px"
    android:paddingBottom="50px"
    android:background="@drawable/bg_transaction">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Edit Current Balance"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:textStyle="bold"
        android:paddingBottom="40px" />

    <EditText
        android:id="@+id/edtNewBalance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="₹ Enter new amount"
        android:textColorHint="#808080"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_glass_input"
        android:padding="40px"
        android:inputType="number"
        android:textSize="18sp"
        android:layout_marginBottom="50px" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="140px"
            android:layout_weight="1"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_glass_input"
            app:backgroundTint="@null"
            android:layout_marginEnd="15px" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="140px"
            android:layout_weight="1"
            android:text="Save"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_glass_input"
            app:backgroundTint="@null"
            android:layout_marginStart="15px" />
    </LinearLayout>
</LinearLayout>
