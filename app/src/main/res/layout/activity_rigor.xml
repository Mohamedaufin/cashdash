<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/bg_main_gradient"
android:paddingLeft="20dp"
    android:paddingRight="20dp"
    android:paddingTop="50dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <EditText
        android:id="@+id/Title"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Title of Expense"
        android:textColor="#FFFFFF"
        android:textColorHint="#A8B5D1"
        android:padding="14dp"
        android:background="@drawable/bg_glass_input"
        android:layout_marginTop="20dp" />

    <!-- PAGE 1: Amount Input -->
    <EditText
        android:id="@+id/inputAmount"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Enter amount"
        android:textColor="#FFFFFF"
        android:textColorHint="#A8B5D1"
        android:padding="14dp"
        android:inputType="number"
        android:background="@drawable/bg_glass_input"
        android:layout_marginTop="20dp" />

    <!-- NEW: Expense Date Selection Label -->
    <TextView
        android:id="@+id/txtDateLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Expense Date"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:layout_marginTop="20dp" />

    <!-- NEW: CalendarView for selecting expense date -->

    <CalendarView
        android:id="@+id/calendarExpense"
        android:layout_width="match_parent"
        android:layout_height="353dp"
        android:layout_marginTop="20dp"


        android:layout_marginBottom="20dp"
        android:background="#09135C" />

    <!-- PAGE 2: Category selection -->

    <Button
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="15dp"
        android:background="@drawable/bg_glass_3d"
        android:text="Next"
        android:textColor="#FFFFFF" />

    <TextView
        android:id="@+id/headingChoose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Expense Allocation"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:layout_marginTop="20dp"
        android:visibility="gone"/>

    <ScrollView
        android:id="@+id/categoryScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/categoryListContainer"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </ScrollView>

    <!-- Back Button -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Back"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_glass_3d"
        android:visibility="gone"
        android:layout_marginBottom="20dp" />

</LinearLayout>
