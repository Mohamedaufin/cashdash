<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Menu button -->
    <ImageView
        android:id="@+id/btnMenu"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="64dp"
        android:src="@drawable/ic_glass_menu_vector"
        android:background="@android:color/transparent"
        android:scaleType="fitCenter"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Greeting -->
    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hello,"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginStart="14dp"
        android:transitionName="greeting_text_transition"
        app:layout_constraintStart_toEndOf="@id/btnMenu"
        app:layout_constraintTop_toTopOf="@id/btnMenu"
        app:layout_constraintBottom_toBottomOf="@id/btnMenu" />

    <!-- Profile button -->
    <ImageView
        android:id="@+id/btnProfile"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:padding="4dp"
        android:src="@drawable/ic_profile"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnMenu"
        app:layout_constraintBottom_toBottomOf="@id/btnMenu"/>

    <TextView
        android:id="@+id/tvNextMoney"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Next money in 0 days"
        android:textColor="#B0C8FF"
        android:textSize="18sp"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/walletContainer"
        android:layout_marginBottom="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- WALLET CIRCLE -->
    <FrameLayout
        android:id="@+id/walletContainer"
        android:layout_width="340dp"
        android:layout_height="340dp"
        android:elevation="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting"
        app:layout_constraintBottom_toTopOf="@id/cardScanner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="65dp"
        android:layout_marginBottom="40dp">

        <View
            android:layout_width="370dp"
            android:layout_height="370dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_wallet_glow"
            android:alpha="0.55"/>

        <com.cash.dash.GradientCircularProgressView
            android:id="@+id/walletProgress"
            android:layout_width="340dp"
            android:layout_height="340dp"
            android:layout_gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="₹5000"
                android:textColor="@android:color/white"
                android:textSize="32sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wallet balance"
                android:textStyle="bold"
                android:textColor="#B0C4FF"
                android:textSize="15sp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- ACTION CARDS -->
    <LinearLayout
        android:id="@+id/cardScanner"
        android:layout_width="120dp"
        android:layout_height="110dp"
        android:layout_marginTop="35dp"
        android:layout_marginStart="32dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_3d_card"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/walletContainer"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/iconScanner"
            android:layout_width="85dp"
            android:layout_height="65dp"
            android:src="@drawable/ic_scanner"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Scanner"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/cardRigor"
        android:layout_width="120dp"
        android:layout_height="110dp"
        android:layout_marginTop="35dp"
        android:layout_marginEnd="32dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_3d_card"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/walletContainer"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iconRigorTracker"
            android:layout_width="85dp"
            android:layout_height="65dp"
            android:src="@drawable/ic_rigor_tracker"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Rigor Tracker"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
