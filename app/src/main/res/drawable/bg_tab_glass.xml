<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Active State: Glow + Stronger Rim -->
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#26FFFFFF"/>
                    <corners android:radius="18dp"/>
                    <stroke android:width="1.5dp" android:color="#A0FFFFFF"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Default State: Soft Glass -->
    <item>
        <layer-list>
            <!-- Outer Rim Shadow/Depth -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#0DFFFFFF"/>
                    <corners android:radius="18dp"/>
                    <stroke android:width="1dp" android:color="#33FFFFFF"/>
                </shape>
            </item>
            <!-- Inner Gradient for Material Depth -->
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#1AFFFFFF"
                        android:endColor="#05FFFFFF"
                        android:angle="135"/>
                    <corners android:radius="17dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
