<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="#132368" />

    <!-- Rounded corners -->
    <corners android:radius="14dp" />

    <!-- Border -->
    <stroke
        android:width="2dp"
        android:color="#4F6BFF"/>

    <!-- Padding inside field -->
    <padding
        android:left="15dp"
        android:top="10dp"
        android:right="15dp"
        android:bottom="10dp"/>
</shape>
