<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. Deep Dark Glass Tint -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F20C0C0F"/> <!-- App BG base -->
            <stroke
                android:width="1dp"
                android:color="@color/border"/>
        </shape>
    </item>

    <!-- 2. Subtle Left-edge Highlight (Bevel effect) -->
    <item
        android:left="0dp"
        android:right="120dp"
        android:top="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#20FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="0"
                android:type="linear"/>
        </shape>
    </item>

</layer-list>
