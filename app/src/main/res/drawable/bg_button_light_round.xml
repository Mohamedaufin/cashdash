<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Smooth circle-like rounded corners -->
    <corners android:radius="50dp" />

    <!-- Light background -->
    <solid android:color="#E4E7FF" />

    <!-- Thin soft border -->
    <stroke
        android:width="2dp"
        android:color="#C7CCFF" />

    <!-- Inner button spacing -->
    <padding
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp" />

</shape>
