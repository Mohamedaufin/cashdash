<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- FOCUSED STATE -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Base: Surface 2 -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/surface_2" />
                    <corners android:radius="16dp" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/primary_purple" />
                </shape>
            </item>
            <!-- Subtle Inner Glow for focus -->
            <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="20dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#157C5CFC"
                        android:endColor="#00000000"
                        android:angle="270" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- DEFAULT STATE -->
    <item>
        <layer-list>
            <!-- Base: Surface 2 (Input fields, chips) -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/surface_2" />
                    <corners android:radius="16dp" />
                    <stroke
                        android:width="1.2dp"
                        android:color="@color/border" />
                </shape>
            </item>
            <!-- Subdued inner glow -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#18FFFFFF"
                        android:endColor="#00FFFFFF"
                        android:angle="270" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
