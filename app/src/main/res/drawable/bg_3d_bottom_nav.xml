<?xml version="1.0" encoding="utf-8"?>
<!-- 3D bottom navigation: dark base + gloss top liner -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Top gloss highlight line -->
    <item
        android:bottom="0dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#506AAA"
                android:endColor="#0A1656"
                android:angle="270"
                android:type="linear"/>
        </shape>
    </item>

    <!-- Inner gradient body -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#122070"
                android:endColor="#060E3A"
                android:angle="270"
                android:type="linear"/>
        </shape>
    </item>

</layer-list>
